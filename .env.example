# Copy this file to .env for local development.
# Do not commit .env. It contains local secrets.

APP_ENV=development
PROJECT_NAME=Azure AI Community Board API

# Local SQL Server container settings.
MSSQL_HOST=db
MSSQL_PORT=1433
MSSQL_DATABASE=community_board_dev
MSSQL_USER=sa
MSSQL_PASSWORD=Replace_with_a_strong_local_password_123!
MSSQL_SA_PASSWORD=Replace_with_a_strong_local_password_123!
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
MSSQL_TRUST_SERVER_CERTIFICATE=true
